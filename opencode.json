{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "jucodex": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Jucodex",
      "options": {
        "baseURL": "https://jucodex.com/v1",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4"
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini"
        }
      }
    }
  },
  "model": "jucodex/gpt-5.4",
  "small_model": "jucodex/gpt-5.4-mini",
  "share": "manual"
}
